modules = ["web", "bash", "nodejs-24"]
  [agent]
expertMode = true
  stack = "BEST_EFFORT_FALLBACK"

  [nix]
  channel = "stable-25_05"

  [workflows]
  runButton = "Project"

  [[workflows.workflow]]
  name = "Project"
  mode = "parallel"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Start application"

  [[workflows.workflow]]
  name = "Start application"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "pnpm --filter boilerplate-web-app dev"
  waitForPort = 5173

  [workflows.workflow.metadata]
  outputType = "webview"

[[ports]]
localPort = 5173
externalPort = 80

  [deployment]
  deploymentTarget = "static"
  build = ["pnpm", "--filter", "boilerplate-web-app", "build"]
  publicDir = "apps/web-app/build/client"
  